# AgentOps Guard provider setup
# Claude-first / Claude-ready provider setup for production clients.
# Add your real model name from your Anthropic dashboard/docs.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude_model_here

# Gemini test-mode setup for local development.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Routing options: auto, claude, gemini, heuristic
DEFAULT_PROVIDER=auto

# Keep real connector execution disabled in public demos.
# Set true only inside a trusted client workspace after approval gates are configured.
ENABLE_REAL_CONNECTORS=false

# Communication connectors
SLACK_WEBHOOK_URL=
GMAIL_SMTP_HOST=
GMAIL_SMTP_PORT=587
GMAIL_SMTP_USER=
GMAIL_SMTP_PASSWORD=
GMAIL_FROM_EMAIL=

# Engineering connectors
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
JIRA_API_TOKEN=
JIRA_EMAIL=
JIRA_BASE_URL=

# Sales / CRM / knowledge connectors
HUBSPOT_API_KEY=
NOTION_API_KEY=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=

# Data / warehouse connectors
DATABASE_URL=
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
